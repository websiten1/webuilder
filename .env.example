# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth — required; used to sign session JWT cookies
SESSION_SECRET=

# AI website generation (Anthropic Claude)
ANTHROPIC_API_KEY=sk_ant_xxxxx

# Support chatbot (OpenAI ChatGPT)
OPENAI_API_KEY=sk-xxxxx
# Optional — defaults to gpt-4o-mini
OPENAI_SUPPORT_MODEL=gpt-4o-mini

# Stripe payments
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Shared secret for webhook-triggered internal calls (e.g. /api/generate-site)
INTERNAL_SECRET=

# Vercel — customer sites deploy via OAuth tokens only (see VERCEL_OAUTH_* below).
# VERCEL_API_TOKEN is not used for customer site deploys.
VERCEL_API_TOKEN=

# Vercel OAuth integration — https://vercel.com/account/integrations
# Redirect URI: {NEXT_PUBLIC_URL}/api/auth/vercel/callback
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=
VERCEL_OAUTH_REDIRECT_URI=

# Encrypts stored Vercel OAuth tokens at rest (64 hex chars = 32 bytes):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Public app URL (no trailing slash)
NEXT_PUBLIC_URL=https://insixlive.com

# Transactional email (Resend)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL="inSIXlive <onboarding@resend.dev>"

# Pexels image search in the generate wizard
PEXELS_API_KEY=

# Set automatically by Vercel in production
NODE_ENV=development
